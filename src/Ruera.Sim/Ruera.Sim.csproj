<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- net9.0 is consumed by the Godot project; net10.0 by tests/CLI/headless (DESIGN.md, CLAUDE.md). -->
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <!-- Determinism enforcement (DESIGN.md §2): bans System.Random, wall-clock APIs, parallelism, GetHashCode. -->
    <PackageReference Include="Microsoft.CodeAnalysis.BannedApiAnalyzers" Version="3.3.4" PrivateAssets="all" />
    <AdditionalFiles Include="BannedSymbols.txt" />
  </ItemGroup>

</Project>
